# Copy this file to .env and fill in the required credentials

# --- Common credentials ---
# BDUSS：请填写百度网盘账号的 BDUSS
BDUSS=
# STOKEN：请填写百度 STOKEN（与 BDUSS 同账号）
STOKEN=
# QUARK_COOKIE：登录夸克网页版后复制完整 Cookie
QUARK_COOKIE=
# QUARK_TARGET_FOLDER_FID：夸克网盘中用于转存的目标目录 fid（例如“影视下载”的 fid）
QUARK_TARGET_FOLDER_FID=

# --- Optional overrides ---
QUARK_TARGET_FOLDER_PATH=影视下载
GLOBAL_HTTP_PROXY=
PLAYWRIGHT_PROXY=

# --- Downloader (8082) configuration ---
# SEARCH_API：PanSou API 地址，默认指向同 compose 中的 pansou 服务
SEARCH_API=http://pansou:8888/api/search
# ALIST_BASE：AList 服务地址，默认指向 compose 中的 alist 服务
ALIST_BASE=http://alist:5244
# AList 登录账号/密码（用于 API 调用）
ALIST_USERNAME=admin
ALIST_PASSWORD=123456
ALIST_QUARK_MOUNT=/夸克网盘
DOWNLOAD_PATH=/downloads
CAPTURE_DIR=/app/captures

# --- Ports exposed on the host ---
# PANSOU_PORT：PanSou 对外暴露端口
PANSOU_PORT=8081
# DOWNLOADER_PORT：Flask 下载器对外端口
DOWNLOADER_PORT=8082
# ALIST_PORT：AList 对外端口
ALIST_PORT=8083

# --- AList configuration ---
ALIST_ADMIN_PASSWORD=123456
# ALIST_DATA：宿主机存放 AList 数据的路径
ALIST_DATA=./data/alist
# SHIPIN_DATA：宿主机存放下载文件的路径（映射到容器 /downloads）
SHIPIN_DATA=./data/shipin
